# Frontend public runtime config
# Solo estas variables son validas para el script de configuracion del frontend.

ATLETA_APP_ENV=development
ATLETA_ENV_NAME=development
ATLETA_API_BASE_URL=http://localhost:8080/api/v1
ATLETA_STORAGE_PREFIX=atleta.dev
# Public OAuth client id. No usar client secret en frontend.
# ATLETA_GOOGLE_CLIENT_ID=tu-client-id.apps.googleusercontent.com

# Variables opcionales para E2E local
E2E_BASE_URL=http://localhost:8100
E2E_API_URL=http://localhost:8080/api/v1
